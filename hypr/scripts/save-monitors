#!/bin/sh
set -eu

config="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/monitors.conf"
log="${XDG_RUNTIME_DIR:-/tmp}/hyprland-save-monitors.log"

fail() {
    printf '%s failed: %s\n' "$(date '+%F %T')" "$*" >>"$log"
    command -v notify-send >/dev/null 2>&1 &&
        notify-send "Display layout save failed" "$*" >/dev/null 2>&1 || true
    exit 1
}

command -v hyprctl >/dev/null 2>&1 || fail "hyprctl is not installed"
command -v python3 >/dev/null 2>&1 || fail "python3 is not installed"

mkdir -p "$(dirname "$config")"

if ! python3 - "$config" "$log" <<'PYEOF'
import json
import subprocess
import sys
from datetime import datetime

config_path, log_path = sys.argv[1], sys.argv[2]

try:
    raw = subprocess.check_output(["hyprctl", "monitors", "-j"], stderr=subprocess.STDOUT)
except subprocess.CalledProcessError as error:
    with open(log_path, "ab") as log:
        log.write(error.output)
    raise SystemExit(1)

monitors = json.loads(raw.decode("utf-8"))

def fmt_float(value):
    try:
        value = float(value)
    except Exception:
        return str(value)
    return str(int(value)) if value.is_integer() else f"{value:g}"

def fmt_refresh(value):
    try:
        value = float(value)
    except Exception:
        return str(value)
    # Hyprland accepts fractional refresh rates; keep useful precision without
    # writing noisy values like 60.00000.
    return f"{value:.3f}".rstrip("0").rstrip(".")

lines = [
    "# TWM Hyprland monitor layout.",
    "# Generated by ~/.config/hypr/scripts/save-monitors.",
    f"# Saved at {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}.",
    "",
]

for monitor in monitors:
    name = monitor.get("name")
    width = monitor.get("width")
    height = monitor.get("height")
    refresh = monitor.get("refreshRate", 0)
    x = monitor.get("x", 0)
    y = monitor.get("y", 0)
    scale = fmt_float(monitor.get("scale", 1))
    transform = int(monitor.get("transform", 0) or 0)

    if not name or not width or not height:
        continue

    mode = f"{width}x{height}@{fmt_refresh(refresh)}"
    position = f"{x}x{y}"
    row = f"monitor = {name},{mode},{position},{scale}"
    if transform:
        row += f",transform,{transform}"
    lines.append(row)

if len(lines) == 4:
    lines.append("monitor = ,preferred,auto,auto")

with open(config_path, "w", encoding="utf-8") as file:
    file.write("\n".join(lines) + "\n")
PYEOF
then
    fail "hyprctl returned no monitor data"
fi

printf '%s saved monitor layout to %s\n' "$(date '+%F %T')" "$config" >>"$log"

if hyprctl reload >>"$log" 2>&1; then
    command -v notify-send >/dev/null 2>&1 &&
        notify-send "Display layout saved" "$config" >/dev/null 2>&1 || true
else
    fail "saved, but hyprctl reload failed: $(tail -n 1 "$log")"
fi
