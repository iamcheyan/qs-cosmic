# TWM Hyprland config
# Install with: ~/.config/TWM/hyprland/setup.sh

source = ~/.config/hypr/env.conf
source = ~/.config/hypr/monitors.conf

$mod = SUPER
$terminal = alacritty
$launcher = ~/.config/hypr/scripts/launcher
$qs = ~/.config/hypr/scripts/quickshell

exec-once = ~/.config/hypr/autostart.sh

general {
    gaps_in = 3
    gaps_out = 3
    border_size = 1
    col.active_border = rgba(4b5563ff)
    col.inactive_border = rgba(262626ff)
    resize_on_border = true
    layout = dwindle
}

decoration {
    rounding = 0
    active_opacity = 1.0
    inactive_opacity = 1.0
    fullscreen_opacity = 1.0

    shadow {
        enabled = true
        range = 12
        render_power = 2
        color = rgba(00000066)
    }
}

animations {
    enabled = false
    bezier = twmEase, 0.16, 1, 0.3, 1
    animation = windows, 1, 3, twmEase
    animation = border, 1, 3, twmEase
    animation = fade, 1, 3, twmEase
    animation = workspaces, 1, 3, twmEase
}

input {
    kb_layout = jp
    follow_mouse = 1
    sensitivity = 0

    touchpad {
        natural_scroll = false
        tap-to-click = true
    }
}

gestures {
    workspace_swipe_touch = true
}

dwindle {
    preserve_split = true
    smart_split = false
}

misc {
    disable_hyprland_logo = true
    disable_splash_rendering = true
    focus_on_activate = true
    mouse_move_enables_dpms = true
    key_press_enables_dpms = true
}

# Applications
bind = $mod, Return, exec, $terminal
bind = $mod, D, exec, $launcher
bind = ALT, Space, exec, ~/.config/quickshell/hyprland/scripts/system-menu
bind = ALT, V, exec, ~/.config/quickshell/hyprland/scripts/cliphist-fuzzel

# Window management
bind = $mod, Q, killactive
bind = $mod, F, fullscreen, 0
bind = $mod, M, fullscreen, 1
# Workspace overview: hold Alt+Tab to show, press Tab to cycle, release Alt to commit
bind = ALT, Tab, global, twm:workspace-overview-next
bindr = ALT, Alt_L, global, twm:workspace-overview-commit
bindr = ALT, Alt_R, global, twm:workspace-overview-commit

bind = $mod SHIFT, Space, togglefloating

# Window switcher (Quickshell): hold $mod+Tab to show, press Tab/Shift+Tab while holding to cycle,
# release $mod (or hit Escape) to apply focus and hide immediately.
# Uses global shortcuts + exclusive keyboard grab in QML for low latency and reliable release detection.
bind = $mod, Tab, global, twm:switcher-next
bind = $mod SHIFT, Tab, global, twm:switcher-prev

# Commit on modifier release (fallback; primary hide is handled inside the grabbed overlay)
bindr = $mod, Super_L, global, twm:switcher-commit
bindr = $mod, Super_R, global, twm:switcher-commit

# Escape fallback (when no grab active). When overlay is grabbed, Escape is handled locally in QML.
bind = , Escape, exec, ~/.config/hypr/scripts/window-switcher hide

bindm = $mod, mouse:272, movewindow
bindm = $mod, mouse:273, resizewindow

# Clipboard-style macOS shortcuts for apps that expect Ctrl.
bind = $mod, C, exec, wtype -M Ctrl c -m Ctrl
bind = $mod, V, exec, wtype -M Ctrl v -m Ctrl
bind = $mod, X, exec, wtype -M Ctrl x -m Ctrl
bind = $mod, Z, exec, wtype -M Ctrl z -m Ctrl
bind = $mod, S, exec, wtype -M Ctrl s -m Ctrl

# Workspaces
bind = ALT, Left, workspace, e-1
bind = ALT, Right, workspace, e+1
bind = ALT, 1, workspace, 1
bind = ALT, 2, workspace, 2
bind = ALT, 3, workspace, 3
bind = ALT, 4, workspace, 4
bind = ALT SHIFT, 1, movetoworkspace, 1
bind = ALT SHIFT, 2, movetoworkspace, 2
bind = ALT SHIFT, 3, movetoworkspace, 3
bind = ALT SHIFT, 4, movetoworkspace, 4

# Screenshot
bind = , Print, exec, ~/.config/hypr/scripts/screenshot-keybind full
bind = ALT, Print, exec, ~/.config/hypr/scripts/screenshot-keybind full-save
bind = SHIFT, Print, exec, ~/.config/hypr/scripts/screenshot-keybind area-save
bind = $mod SHIFT, A, exec, ~/.config/hypr/scripts/screenshot-keybind area

# Media / hardware
bind = , XF86MonBrightnessUp, exec, ~/.config/hypr/scripts/brightness-control up
bind = , XF86MonBrightnessDown, exec, ~/.config/hypr/scripts/brightness-control down
bind = , XF86AudioRaiseVolume, exec, pactl set-sink-volume @DEFAULT_SINK@ +2% && quickshell -p ~/.config/quickshell/hyprland ipc call volume-helper triggerUpdate
bind = , XF86AudioLowerVolume, exec, pactl set-sink-volume @DEFAULT_SINK@ -2% && quickshell -p ~/.config/quickshell/hyprland ipc call volume-helper triggerUpdate
bind = , XF86AudioMute, exec, pactl set-sink-mute @DEFAULT_SINK@ toggle && quickshell -p ~/.config/quickshell/hyprland ipc call volume-helper triggerUpdate

# Optional voice input.
bind = ALT, A, exec, sh -c 'PATH=$HOME/.local/bin:$PATH kazamo toggle'

# Useful floating/pop-up rules.
windowrule = match:class wofi, float on
windowrule = match:class fuzzel, float on
windowrule = match:class pavucontrol, float on
windowrule = match:class blueman-manager, float on
windowrule = match:title Picture-in-Picture, float on
windowrule = match:title Picture-in-Picture, pin on
